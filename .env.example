# ─────────────────────────────────────────────────────────────────────────────
# Hyu environment variables
#
# Copy this file to `.env` and fill in real values:  cp .env.example .env
#
# Anything prefixed with EXPO_PUBLIC_ is inlined into the client bundle and is
# therefore CLIENT-SAFE ONLY. Never put secrets here.
# ─────────────────────────────────────────────────────────────────────────────

# --- CLIENT-SAFE (shipped in the app bundle) ---------------------------------
# Supabase project URL, e.g. https://abcdefgh.supabase.co
EXPO_PUBLIC_SUPABASE_URL=

# Supabase anon (public) key. Safe to ship: every table is protected by RLS.
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# SERVER-ONLY — DO NOT put these in .env for the app, and never commit them.
# These are set as Supabase secrets for the Edge Functions:
#
#   supabase secrets set USDA_FDC_API_KEY=your_key_here
#
# (SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY are injected automatically into the
#  Edge Function runtime by Supabase — you do not set them yourself.)
# ─────────────────────────────────────────────────────────────────────────────
# USDA_FDC_API_KEY=          # get one free at https://fdc.nal.usda.gov/api-key-signup.html
